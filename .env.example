# Copy to .env (or set these in your shell) before running the app.
# All are optional — RadMatcher runs without them.

# Password for entering Training Mode in the UI. Change this!
RADMATCHER_PASSWORD=radmatcher

# Flask session secret. Set a long random value to keep training-mode logins
# valid across restarts. If unset, a random key is generated each start.
RADMATCHER_SECRET=

# Optional: bind host/port (defaults are 0.0.0.0:5000). See app.py.
# RADMATCHER_HOST=0.0.0.0
# RADMATCHER_PORT=5000
